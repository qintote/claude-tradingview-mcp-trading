# ── Scheduling ────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
ASSET=XAUUSD
BOT_COMMAND=node
BOT_ARGS=bot.js --mode=scan

# ── File lock ─────────────────────────────────────────────────────────────────
LOCK_DIR=/tmp
LOCK_NAME=xauusd_scanner
LOCK_TTL_SECONDS=300

# ── Retry ─────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5.0

# ── Health ────────────────────────────────────────────────────────────────────
MAX_CONSECUTIVE_FAILURES=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Capital.com ─────────────────────────────────────────────────────────────
# Get your API key: Capital.com → Profile → API Keys
CAPITAL_API_KEY=your_api_key_here
CAPITAL_EMAIL=your@email.com
CAPITAL_PASSWORD=your_password_here
CAPITAL_DEMO=false               # true = demo account | false = live account

# ─── Instrument ──────────────────────────────────────────────────────────────
CAPITAL_EPIC=GOLD
TIMEFRAME=HOUR_4

# ─── Trade sizing ────────────────────────────────────────────────────────────
CAPITAL_TRADE_SIZE=1

# ─── Risk guardrails ─────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=1000
MAX_TRADE_SIZE_USD=100
MAX_TRADES_PER_DAY=3

# ─── Mode ────────────────────────────────────────────────────────────────────
PAPER_TRADING=false

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated E.164 numbers allowed to access the Telegram bot
ALLOWED_PHONES=+971556698487,+251940929739

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── TradingView ─────────────────────────────────────────────────────────────
TV_SYMBOL=OANDA:XAUUSD
