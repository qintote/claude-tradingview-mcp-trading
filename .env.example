# ─── Capital.com ─────────────────────────────────────────────────────────────
# Get your API key: Capital.com → Profile → API Keys
CAPITAL_API_KEY=your_api_key_here
CAPITAL_EMAIL=your@email.com
CAPITAL_PASSWORD=your_password_here
CAPITAL_DEMO=true                # true = demo account | false = live account

# ─── Exness / MT5 ────────────────────────────────────────────────────────────
# The EA reads/writes files in your MT5 data folder.
# In MT5: File → Open Data Folder → MQL5 → Files
# Paste that full path below (Mac example shown):
MT5_FILES_DIR=/Users/yourname/Library/Application Support/MetaTrader 5/MQL5/Files
MT5_ENABLED=true

# ─── Instrument ──────────────────────────────────────────────────────────────
# Capital.com epic (the instrument ID used in their API)
# Examples: GOLD  EURUSD  GBPUSD  GBPJPY  US500  OIL_CRUDE
CAPITAL_EPIC=GOLD

# MT5 symbol (must match the symbol name in your MT5 Market Watch)
# Examples: XAUUSD  EURUSD  GBPUSD  GBPJPY  US500  USOIL
MT5_SYMBOL=XAUUSD

# Candle timeframe for Capital.com market data
# Options: MINUTE  MINUTE_5  MINUTE_15  MINUTE_30  HOUR  HOUR_4  DAY  WEEK
TIMEFRAME=HOUR_4

# ─── Trade sizing ────────────────────────────────────────────────────────────
# Capital.com — size in units (check the deal ticket on Capital.com for minimums)
CAPITAL_TRADE_SIZE=1

# MT5 — lot size (0.01 = micro lot, 0.1 = mini lot, 1.0 = standard lot)
MT5_LOT_SIZE=0.01

# ─── Risk guardrails ─────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=1000
MAX_TRADE_SIZE_USD=100
MAX_TRADES_PER_DAY=3

# ─── Mode ────────────────────────────────────────────────────────────────────
# true  = log decisions, never place real orders (safe to start here)
# false = live trading — flip only after watching paper trades for a few days
PAPER_TRADING=true

# ─── Telegram approval ───────────────────────────────────────────────────────
# When set, every valid setup sends a Telegram message with Approve/Reject buttons.
# Orders are only placed after you tap Approve (10-minute window).
#
# Setup:
#  1. Message @BotFather on Telegram → /newbot → copy the token
#  2. Send any message to your new bot, then open:
#     https://api.telegram.org/bot<TOKEN>/getUpdates
#     Copy the "id" value inside "chat" — that's your TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
